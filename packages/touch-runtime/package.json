{
  "name": "@touchai/touch-runtime",
  "version": "0.2.0",
  "description": "Touch Language runtime: gesture segmentation, session normalization, rule engine, haptic materialization",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/EricSense/TouchAI.git",
    "directory": "packages/touch-runtime"
  },
  "homepage": "https://github.com/EricSense/TouchAI#install",
  "bugs": {
    "url": "https://github.com/EricSense/TouchAI/issues"
  },
  "keywords": ["touchai", "touch", "gestures", "haptics", "ai", "touch-language", "runtime"],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@touchai/touch-spec": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=20"
  }
}
