{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "HapticProgram",
  "description": "Platform-neutral haptic pulse program. Regenerate via npm run build -w @touchai/touch-spec",
  "type": "object",
  "required": ["id", "pulses"],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "pulses": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["delayMs", "intensity", "sharpness", "durationMs"],
        "properties": {
          "delayMs": { "type": "number", "minimum": 0 },
          "intensity": { "type": "number", "minimum": 0, "maximum": 1 },
          "sharpness": { "type": "number", "minimum": 0, "maximum": 1 },
          "durationMs": { "type": "number", "exclusiveMinimum": 0 }
        }
      }
    }
  }
}
