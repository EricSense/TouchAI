{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TouchEventEnvelope",
  "description": "Versioned wire envelope for Touch Language sessions. Regenerate via npm run build -w @touchai/touch-spec",
  "type": "object",
  "required": ["specVersion", "sessionId"],
  "properties": {
    "specVersion": { "type": "string", "const": "0.1.0" },
    "sessionId": { "type": "string", "minLength": 1 },
    "deviceProfile": {
      "type": "object",
      "properties": {
        "vendor": { "type": "string" },
        "model": { "type": "string" },
        "os": { "type": "string" },
        "maxPointers": { "type": "integer", "minimum": 1 }
      }
    },
    "stream": { "type": "array", "items": { "$ref": "#/$defs/TouchSample" } },
    "gesture": { "$ref": "#/$defs/GestureToken" },
    "intent": {
      "type": "object",
      "required": ["intentId", "confidence"],
      "properties": {
        "intentId": { "type": "string" },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "slots": { "type": "object" }
      }
    },
    "haptic": { "$ref": "#/$defs/HapticSemantic" }
  },
  "$defs": {
    "TouchSample": {
      "type": "object",
      "required": ["tMs", "phase", "pointerId", "x", "y"],
      "properties": {
        "tMs": { "type": "number", "minimum": 0 },
        "phase": { "enum": ["began", "moved", "ended", "cancelled"] },
        "pointerId": { "type": "integer", "minimum": 0 },
        "x": { "type": "number", "minimum": 0, "maximum": 1 },
        "y": { "type": "number", "minimum": 0, "maximum": 1 },
        "pressure": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "GestureToken": { "type": "object" },
    "HapticSemantic": { "type": "object", "required": ["kind"], "properties": { "kind": { "type": "string" } } }
  }
}
