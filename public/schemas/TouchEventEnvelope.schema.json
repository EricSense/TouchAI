{
  "$ref": "#/definitions/TouchEventEnvelope",
  "definitions": {
    "TouchEventEnvelope": {
      "type": "object",
      "properties": {
        "specVersion": {
          "type": "string",
          "const": "0.2.0"
        },
        "sessionId": {
          "type": "string",
          "minLength": 1
        },
        "deviceProfile": {
          "type": "object",
          "properties": {
            "vendor": {
              "type": "string"
            },
            "model": {
              "type": "string"
            },
            "os": {
              "type": "string"
            },
            "maxPointers": {
              "type": "integer",
              "exclusiveMinimum": 0
            }
          },
          "additionalProperties": false
        },
        "sessionProfile": {
          "type": "object",
          "properties": {
            "sampleCount": {
              "type": "integer",
              "minimum": 0
            },
            "velocityBaseline": {
              "type": "number",
              "minimum": 0
            },
            "pressureBaseline": {
              "type": "number",
              "exclusiveMinimum": 0
            }
          },
          "required": [
            "sampleCount",
            "velocityBaseline",
            "pressureBaseline"
          ],
          "additionalProperties": false
        },
        "stream": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "tMs": {
                "type": "number",
                "minimum": 0
              },
              "phase": {
                "type": "string",
                "enum": [
                  "began",
                  "moved",
                  "ended",
                  "cancelled"
                ]
              },
              "pointerId": {
                "type": "integer",
                "minimum": 0
              },
              "x": {
                "type": "number",
                "minimum": 0,
                "maximum": 1
              },
              "y": {
                "type": "number",
                "minimum": 0,
                "maximum": 1
              },
              "pressure": {
                "type": "number",
                "minimum": 0,
                "maximum": 1
              }
            },
            "required": [
              "tMs",
              "phase",
              "pointerId",
              "x",
              "y"
            ],
            "additionalProperties": false
          }
        },
        "gesture": {
          "anyOf": [
            {
              "type": "object",
              "properties": {
                "kind": {
                  "type": "string",
                  "const": "tap"
                },
                "center": {
                  "type": "object",
                  "properties": {
                    "x": {
                      "type": "number"
                    },
                    "y": {
                      "type": "number"
                    }
                  },
                  "required": [
                    "x",
                    "y"
                  ],
                  "additionalProperties": false
                },
                "pointerCount": {
                  "type": "integer",
                  "minimum": 1,
                  "maximum": 10
                },
                "durationMs": {
                  "type": "number",
                  "minimum": 0
                }
              },
              "required": [
                "kind",
                "center",
                "pointerCount",
                "durationMs"
              ],
              "additionalProperties": false
            },
            {
              "type": "object",
              "properties": {
                "kind": {
                  "type": "string",
                  "const": "long_press"
                },
                "center": {
                  "type": "object",
                  "properties": {
                    "x": {
                      "type": "number"
                    },
                    "y": {
                      "type": "number"
                    }
                  },
                  "required": [
                    "x",
                    "y"
                  ],
                  "additionalProperties": false
                },
                "durationMs": {
                  "type": "number",
                  "exclusiveMinimum": 0
                },
                "pointerCount": {
                  "type": "integer",
                  "minimum": 1,
                  "maximum": 10
                }
              },
              "required": [
                "kind",
                "center",
                "durationMs",
                "pointerCount"
              ],
              "additionalProperties": false
            },
            {
              "type": "object",
              "properties": {
                "kind": {
                  "type": "string",
                  "const": "swipe"
                },
                "origin": {
                  "type": "object",
                  "properties": {
                    "x": {
                      "type": "number"
                    },
                    "y": {
                      "type": "number"
                    }
                  },
                  "required": [
                    "x",
                    "y"
                  ],
                  "additionalProperties": false
                },
                "vector": {
                  "type": "object",
                  "properties": {
                    "dx": {
                      "type": "number"
                    },
                    "dy": {
                      "type": "number"
                    }
                  },
                  "required": [
                    "dx",
                    "dy"
                  ],
                  "additionalProperties": false
                },
                "velocity": {
                  "type": "number",
                  "minimum": 0
                },
                "pointerCount": {
                  "type": "integer",
                  "minimum": 1,
                  "maximum": 10
                }
              },
              "required": [
                "kind",
                "origin",
                "vector",
                "velocity",
                "pointerCount"
              ],
              "additionalProperties": false
            },
            {
              "type": "object",
              "properties": {
                "kind": {
                  "type": "string",
                  "const": "pan"
                },
                "delta": {
                  "type": "object",
                  "properties": {
                    "dx": {
                      "type": "number"
                    },
                    "dy": {
                      "type": "number"
                    }
                  },
                  "required": [
                    "dx",
                    "dy"
                  ],
                  "additionalProperties": false
                },
                "pointerCount": {
                  "type": "integer",
                  "minimum": 1,
                  "maximum": 10
                }
              },
              "required": [
                "kind",
                "delta",
                "pointerCount"
              ],
              "additionalProperties": false
            },
            {
              "type": "object",
              "properties": {
                "kind": {
                  "type": "string",
                  "const": "pinch"
                },
                "center": {
                  "type": "object",
                  "properties": {
                    "x": {
                      "type": "number"
                    },
                    "y": {
                      "type": "number"
                    }
                  },
                  "required": [
                    "x",
                    "y"
                  ],
                  "additionalProperties": false
                },
                "scale": {
                  "type": "number",
                  "exclusiveMinimum": 0
                },
                "pointerCount": {
                  "type": "number",
                  "const": 2
                },
                "durationMs": {
                  "type": "number",
                  "minimum": 0
                }
              },
              "required": [
                "kind",
                "center",
                "scale",
                "pointerCount",
                "durationMs"
              ],
              "additionalProperties": false
            },
            {
              "type": "object",
              "properties": {
                "kind": {
                  "type": "string",
                  "const": "two_finger_swipe"
                },
                "origin": {
                  "type": "object",
                  "properties": {
                    "x": {
                      "type": "number"
                    },
                    "y": {
                      "type": "number"
                    }
                  },
                  "required": [
                    "x",
                    "y"
                  ],
                  "additionalProperties": false
                },
                "vector": {
                  "type": "object",
                  "properties": {
                    "dx": {
                      "type": "number"
                    },
                    "dy": {
                      "type": "number"
                    }
                  },
                  "required": [
                    "dx",
                    "dy"
                  ],
                  "additionalProperties": false
                },
                "velocity": {
                  "type": "number",
                  "minimum": 0
                },
                "pointerCount": {
                  "type": "number",
                  "const": 2
                }
              },
              "required": [
                "kind",
                "origin",
                "vector",
                "velocity",
                "pointerCount"
              ],
              "additionalProperties": false
            }
          ]
        },
        "intent": {
          "type": "object",
          "properties": {
            "intentId": {
              "type": "string",
              "minLength": 1
            },
            "confidence": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "slots": {
              "type": "object",
              "additionalProperties": {}
            }
          },
          "required": [
            "intentId",
            "confidence"
          ],
          "additionalProperties": false
        },
        "haptic": {
          "anyOf": [
            {
              "type": "object",
              "properties": {
                "kind": {
                  "type": "string",
                  "const": "ack_light"
                }
              },
              "required": [
                "kind"
              ],
              "additionalProperties": false
            },
            {
              "type": "object",
              "properties": {
                "kind": {
                  "type": "string",
                  "const": "ack_medium"
                }
              },
              "required": [
                "kind"
              ],
              "additionalProperties": false
            },
            {
              "type": "object",
              "properties": {
                "kind": {
                  "type": "string",
                  "const": "ack_heavy"
                }
              },
              "required": [
                "kind"
              ],
              "additionalProperties": false
            },
            {
              "type": "object",
              "properties": {
                "kind": {
                  "type": "string",
                  "const": "confirm_success"
                }
              },
              "required": [
                "kind"
              ],
              "additionalProperties": false
            },
            {
              "type": "object",
              "properties": {
                "kind": {
                  "type": "string",
                  "const": "confirm_warning"
                }
              },
              "required": [
                "kind"
              ],
              "additionalProperties": false
            },
            {
              "type": "object",
              "properties": {
                "kind": {
                  "type": "string",
                  "const": "confirm_error"
                }
              },
              "required": [
                "kind"
              ],
              "additionalProperties": false
            },
            {
              "type": "object",
              "properties": {
                "kind": {
                  "type": "string",
                  "const": "understood"
                }
              },
              "required": [
                "kind"
              ],
              "additionalProperties": false
            },
            {
              "type": "object",
              "properties": {
                "kind": {
                  "type": "string",
                  "const": "clarify"
                }
              },
              "required": [
                "kind"
              ],
              "additionalProperties": false
            },
            {
              "type": "object",
              "properties": {
                "kind": {
                  "type": "string",
                  "const": "custom"
                },
                "program": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "string",
                      "minLength": 1
                    },
                    "pulses": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "delayMs": {
                            "type": "number",
                            "minimum": 0
                          },
                          "intensity": {
                            "type": "number",
                            "minimum": 0,
                            "maximum": 1
                          },
                          "sharpness": {
                            "type": "number",
                            "minimum": 0,
                            "maximum": 1
                          },
                          "durationMs": {
                            "type": "number",
                            "exclusiveMinimum": 0
                          }
                        },
                        "required": [
                          "delayMs",
                          "intensity",
                          "sharpness",
                          "durationMs"
                        ],
                        "additionalProperties": false
                      },
                      "minItems": 1
                    }
                  },
                  "required": [
                    "id",
                    "pulses"
                  ],
                  "additionalProperties": false
                }
              },
              "required": [
                "kind",
                "program"
              ],
              "additionalProperties": false
            }
          ]
        }
      },
      "required": [
        "specVersion",
        "sessionId"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
