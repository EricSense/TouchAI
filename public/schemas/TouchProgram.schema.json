{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TouchProgram",
  "description": "Declarative Touch Language program (rules IR). Regenerate via npm run build -w @touchai/touch-spec",
  "type": "object",
  "required": ["rules"],
  "properties": {
    "_meta": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "specVersion": { "type": "string" }
      }
    },
    "rules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "when", "then"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "when": {
            "type": "object",
            "properties": {
              "gesture": { "type": "object" },
              "match": {
                "type": "object",
                "properties": {
                  "kind": { "enum": ["tap", "long_press", "swipe", "pan"] },
                  "pointerCount": { "type": "integer", "minimum": 1, "maximum": 10 },
                  "direction": { "enum": ["up", "down", "left", "right"] },
                  "minDurationMs": { "type": "number", "minimum": 0 },
                  "maxDurationMs": { "type": "number", "minimum": 0 },
                  "minVelocity": { "type": "number", "minimum": 0 },
                  "region": {
                    "type": "object",
                    "required": ["x0", "y0", "x1", "y1"],
                    "properties": {
                      "x0": { "type": "number" },
                      "y0": { "type": "number" },
                      "x1": { "type": "number" },
                      "y1": { "type": "number" }
                    }
                  }
                }
              }
            }
          },
          "then": {
            "type": "object",
            "properties": {
              "intent": {
                "type": "object",
                "required": ["intentId", "confidence"],
                "properties": {
                  "intentId": { "type": "string" },
                  "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
                }
              },
              "haptic": { "type": "object", "required": ["kind"] }
            }
          }
        }
      }
    }
  }
}
