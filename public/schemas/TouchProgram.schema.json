{
  "$ref": "#/definitions/TouchProgram",
  "definitions": {
    "TouchProgram": {
      "type": "object",
      "properties": {
        "_meta": {
          "type": "object",
          "properties": {
            "name": {
              "type": "string"
            },
            "description": {
              "type": "string"
            },
            "specVersion": {
              "type": "string"
            }
          },
          "additionalProperties": false
        },
        "rules": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "minLength": 1
              },
              "when": {
                "type": "object",
                "properties": {
                  "gesture": {
                    "anyOf": [
                      {
                        "type": "object",
                        "properties": {
                          "kind": {
                            "type": "string",
                            "const": "tap"
                          },
                          "center": {
                            "type": "object",
                            "properties": {
                              "x": {
                                "type": "number"
                              },
                              "y": {
                                "type": "number"
                              }
                            },
                            "required": [
                              "x",
                              "y"
                            ],
                            "additionalProperties": false
                          },
                          "pointerCount": {
                            "type": "integer",
                            "minimum": 1,
                            "maximum": 10
                          },
                          "durationMs": {
                            "type": "number",
                            "minimum": 0
                          }
                        },
                        "required": [
                          "kind",
                          "center",
                          "pointerCount",
                          "durationMs"
                        ],
                        "additionalProperties": false
                      },
                      {
                        "type": "object",
                        "properties": {
                          "kind": {
                            "type": "string",
                            "const": "long_press"
                          },
                          "center": {
                            "type": "object",
                            "properties": {
                              "x": {
                                "type": "number"
                              },
                              "y": {
                                "type": "number"
                              }
                            },
                            "required": [
                              "x",
                              "y"
                            ],
                            "additionalProperties": false
                          },
                          "durationMs": {
                            "type": "number",
                            "exclusiveMinimum": 0
                          },
                          "pointerCount": {
                            "type": "integer",
                            "minimum": 1,
                            "maximum": 10
                          }
                        },
                        "required": [
                          "kind",
                          "center",
                          "durationMs",
                          "pointerCount"
                        ],
                        "additionalProperties": false
                      },
                      {
                        "type": "object",
                        "properties": {
                          "kind": {
                            "type": "string",
                            "const": "swipe"
                          },
                          "origin": {
                            "type": "object",
                            "properties": {
                              "x": {
                                "type": "number"
                              },
                              "y": {
                                "type": "number"
                              }
                            },
                            "required": [
                              "x",
                              "y"
                            ],
                            "additionalProperties": false
                          },
                          "vector": {
                            "type": "object",
                            "properties": {
                              "dx": {
                                "type": "number"
                              },
                              "dy": {
                                "type": "number"
                              }
                            },
                            "required": [
                              "dx",
                              "dy"
                            ],
                            "additionalProperties": false
                          },
                          "velocity": {
                            "type": "number",
                            "minimum": 0
                          },
                          "pointerCount": {
                            "type": "integer",
                            "minimum": 1,
                            "maximum": 10
                          }
                        },
                        "required": [
                          "kind",
                          "origin",
                          "vector",
                          "velocity",
                          "pointerCount"
                        ],
                        "additionalProperties": false
                      },
                      {
                        "type": "object",
                        "properties": {
                          "kind": {
                            "type": "string",
                            "const": "pan"
                          },
                          "delta": {
                            "type": "object",
                            "properties": {
                              "dx": {
                                "type": "number"
                              },
                              "dy": {
                                "type": "number"
                              }
                            },
                            "required": [
                              "dx",
                              "dy"
                            ],
                            "additionalProperties": false
                          },
                          "pointerCount": {
                            "type": "integer",
                            "minimum": 1,
                            "maximum": 10
                          }
                        },
                        "required": [
                          "kind",
                          "delta",
                          "pointerCount"
                        ],
                        "additionalProperties": false
                      }
                    ]
                  },
                  "match": {
                    "type": "object",
                    "properties": {
                      "kind": {
                        "type": "string",
                        "enum": [
                          "tap",
                          "long_press",
                          "swipe",
                          "pan"
                        ]
                      },
                      "pointerCount": {
                        "type": "integer",
                        "minimum": 1,
                        "maximum": 10
                      },
                      "region": {
                        "type": "object",
                        "properties": {
                          "x0": {
                            "type": "number",
                            "minimum": 0,
                            "maximum": 1
                          },
                          "y0": {
                            "type": "number",
                            "minimum": 0,
                            "maximum": 1
                          },
                          "x1": {
                            "type": "number",
                            "minimum": 0,
                            "maximum": 1
                          },
                          "y1": {
                            "type": "number",
                            "minimum": 0,
                            "maximum": 1
                          }
                        },
                        "required": [
                          "x0",
                          "y0",
                          "x1",
                          "y1"
                        ],
                        "additionalProperties": false
                      },
                      "minDurationMs": {
                        "type": "number",
                        "minimum": 0
                      },
                      "maxDurationMs": {
                        "type": "number",
                        "minimum": 0
                      },
                      "direction": {
                        "type": "string",
                        "enum": [
                          "up",
                          "down",
                          "left",
                          "right"
                        ]
                      },
                      "minVelocity": {
                        "type": "number",
                        "minimum": 0
                      }
                    },
                    "additionalProperties": false
                  }
                },
                "additionalProperties": false
              },
              "then": {
                "type": "object",
                "properties": {
                  "intent": {
                    "type": "object",
                    "properties": {
                      "intentId": {
                        "type": "string",
                        "minLength": 1
                      },
                      "confidence": {
                        "type": "number",
                        "minimum": 0,
                        "maximum": 1
                      },
                      "slots": {
                        "type": "object",
                        "additionalProperties": {}
                      }
                    },
                    "required": [
                      "intentId",
                      "confidence"
                    ],
                    "additionalProperties": false
                  },
                  "haptic": {
                    "anyOf": [
                      {
                        "type": "object",
                        "properties": {
                          "kind": {
                            "type": "string",
                            "const": "ack_light"
                          }
                        },
                        "required": [
                          "kind"
                        ],
                        "additionalProperties": false
                      },
                      {
                        "type": "object",
                        "properties": {
                          "kind": {
                            "type": "string",
                            "const": "ack_medium"
                          }
                        },
                        "required": [
                          "kind"
                        ],
                        "additionalProperties": false
                      },
                      {
                        "type": "object",
                        "properties": {
                          "kind": {
                            "type": "string",
                            "const": "ack_heavy"
                          }
                        },
                        "required": [
                          "kind"
                        ],
                        "additionalProperties": false
                      },
                      {
                        "type": "object",
                        "properties": {
                          "kind": {
                            "type": "string",
                            "const": "confirm_success"
                          }
                        },
                        "required": [
                          "kind"
                        ],
                        "additionalProperties": false
                      },
                      {
                        "type": "object",
                        "properties": {
                          "kind": {
                            "type": "string",
                            "const": "confirm_warning"
                          }
                        },
                        "required": [
                          "kind"
                        ],
                        "additionalProperties": false
                      },
                      {
                        "type": "object",
                        "properties": {
                          "kind": {
                            "type": "string",
                            "const": "confirm_error"
                          }
                        },
                        "required": [
                          "kind"
                        ],
                        "additionalProperties": false
                      },
                      {
                        "type": "object",
                        "properties": {
                          "kind": {
                            "type": "string",
                            "const": "understood"
                          }
                        },
                        "required": [
                          "kind"
                        ],
                        "additionalProperties": false
                      },
                      {
                        "type": "object",
                        "properties": {
                          "kind": {
                            "type": "string",
                            "const": "clarify"
                          }
                        },
                        "required": [
                          "kind"
                        ],
                        "additionalProperties": false
                      },
                      {
                        "type": "object",
                        "properties": {
                          "kind": {
                            "type": "string",
                            "const": "custom"
                          },
                          "program": {
                            "type": "object",
                            "properties": {
                              "id": {
                                "type": "string",
                                "minLength": 1
                              },
                              "pulses": {
                                "type": "array",
                                "items": {
                                  "type": "object",
                                  "properties": {
                                    "delayMs": {
                                      "type": "number",
                                      "minimum": 0
                                    },
                                    "intensity": {
                                      "type": "number",
                                      "minimum": 0,
                                      "maximum": 1
                                    },
                                    "sharpness": {
                                      "type": "number",
                                      "minimum": 0,
                                      "maximum": 1
                                    },
                                    "durationMs": {
                                      "type": "number",
                                      "exclusiveMinimum": 0
                                    }
                                  },
                                  "required": [
                                    "delayMs",
                                    "intensity",
                                    "sharpness",
                                    "durationMs"
                                  ],
                                  "additionalProperties": false
                                },
                                "minItems": 1
                              }
                            },
                            "required": [
                              "id",
                              "pulses"
                            ],
                            "additionalProperties": false
                          }
                        },
                        "required": [
                          "kind",
                          "program"
                        ],
                        "additionalProperties": false
                      }
                    ]
                  }
                },
                "additionalProperties": false
              }
            },
            "required": [
              "id",
              "when",
              "then"
            ],
            "additionalProperties": false
          }
        }
      },
      "required": [
        "rules"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
